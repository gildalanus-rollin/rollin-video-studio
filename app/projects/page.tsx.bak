import Link from 'next/link'
import TopNav from '@/components/TopNav'
import { supabase } from '@/lib/supabase'

type Project = {
  id: string
  title: string
  category: string | null
  status: string
  duration_limit_seconds: number
  output_format: string
  created_at: string
  main_source_url: string | null
}

export default async function ProjectsPage() {
  const { data, error } = await supabase
    .from('projects')
    .select('id, title, category, status, duration_limit_seconds, output_format, created_at, main_source_url')
    .order('created_at', { ascending: false })

  const projects = (data ?? []) as Project[]

  return (
    <main className="min-h-screen bg-neutral-100 text-neutral-900 p-10">
      <div className="max-w-6xl mx-auto">
        <TopNav />

        <div className="flex items-center justify-between mb-8 gap-4">
          <div>
            <h1 className="text-4xl font-bold mb-3">Proyectos</h1>
            <p className="text-lg text-neutral-600">
              Acá ves todos los proyectos guardados en la base.
            </p>
          </div>

          <Link
            href="/projects/new"
            className="rounded-xl bg-neutral-900 px-5 py-3 text-white font-medium hover:opacity-90"
          >
            Nuevo proyecto
          </Link>
        </div>

        {error ? (
          <div className="rounded-xl border border-red-200 bg-red-50 p-4 text-red-700">
            Error al leer proyectos: {error.message}
          </div>
        ) : projects.length === 0 ? (
          <div className="rounded-2xl border border-neutral-200 bg-white p-6 text-neutral-600">
            No hay proyectos cargados todavía.
          </div>
        ) : (
          <div className="grid grid-cols-1 md:grid-cols-2 gap-5">
            {projects.map((project) => (
              <div
                key={project.id}
                className="rounded-2xl border border-neutral-200 bg-white p-6"
              >
                <div className="flex items-start justify-between gap-3 mb-4">
                  <h2 className="text-2xl font-semibold leading-tight">
                    {project.title}
                  </h2>
                  <span className="rounded-full border border-neutral-300 px-3 py-1 text-xs text-neutral-600 whitespace-nowrap">
                    {project.status}
                  </span>
                </div>

                <div className="space-y-2 text-sm text-neutral-700 mb-4">
                  <p><strong>Categoría:</strong> {project.category ?? 'General'}</p>
                  <p><strong>Duración:</strong> {project.duration_limit_seconds}s</p>
                  <p><strong>Formato:</strong> {project.output_format}</p>
                  <p>
                    <strong>Creado:</strong>{' '}
                    {new Date(project.created_at).toLocaleString('es-AR')}
                  </p>
                </div>

                {project.main_source_url ? (
<div className="flex flex-col gap-3">
                  <a
                    href={project.main_source_url}
                    target="_blank"
                    rel="noreferrer"
                    className="inline-flex text-sm text-neutral-900 underline underline-offset-4"
                  >
Ver fuente principal
    </a>

    <Link
      href={`/projects/${project.id}`}
      className="inline-flex text-sm text-neutral-900 
underline underline-offset-4"
    >
      Ver detalle
    </Link>
  </div>
) : (
  <div className="flex flex-col gap-3">
    <p className="text-sm text-neutral-500">
      Sin fuente principal cargada.
    </p>

    <Link
      href={`/projects/${project.id}`}
      className="inline-flex text-sm text-neutral-900 
underline underline-offset-4"
    >
      Ver detalle
    </Link>
  </div>
)}
